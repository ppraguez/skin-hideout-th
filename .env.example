# Copy to .env for local dev, and set these in your host (Vercel) dashboard for production.
# NEVER commit the real .env — it is gitignored.

# --- Supabase (required) ---
# Server-side. SERVICE_ROLE is secret — get it from Supabase → Project Settings → API.
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_PUBLISHABLE_KEY=your-publishable-anon-key
SUPABASE_PROJECT_ID=your-project-id

# Client-side (inlined into the browser bundle at build time — publishable/safe).
VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-publishable-anon-key
VITE_SUPABASE_PROJECT_ID=your-project-id

# --- Sessions (required for Steam login) ---
# Must be at least 32 characters. Generate one with: openssl rand -base64 48
SESSION_SECRET=replace-with-a-long-random-string-min-32-chars

# --- Steam (required for login) ---
# Get a key at https://steamcommunity.com/dev/apikey
STEAM_API_KEY=your-steam-web-api-key

# --- Optional features (pages still load without these) ---
# Live esports matches (https://pandascore.co)
PANDASCORE_API_KEY=
# Quick-Buy auto-pricing (https://pricempire.com)
PRICEMPIRE_API_KEY=
